#     #     zone auth_zone 2r/s {
#     #         key /api/auth
#     #     }
#     # }
#
#     # Access logging
#     log {
#         output file /var/log/caddy/onit-access.log {
#             roll_size 50mb
#             roll_keep 10
#         }
#         format json
#     }
#
#     # Block common attack paths
#     @blockpaths path /wp-admin* /wp-login* /xmlrpc* /.env* /admin.php*
#     respond @blockpaths 403 {
#         close
#     }
# }

# ── Development/Local configuration (current) ──
:81 {
        handle {
                reverse_proxy localhost:3000 {
                        header_up Host {host}
                        header_up X-Forwarded-For {remote_host}
                        header_up X-Forwarded-Proto {scheme}
                        header_up X-Real-IP {remote_host}
                }
        }

        # Basic security headers even in dev
        header {
                X-Content-Type-Options "nosniff"
                X-Frame-Options "SAMEORIGIN"
                -Server
        }
}

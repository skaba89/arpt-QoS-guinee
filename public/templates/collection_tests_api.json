    "password": "Admin@2026!",
    "loginEndpoint": "/api/auth/callback/credentials"
  },
  "tests": [
    {
      "id": 1,
      "name": "Import Drive Test CSV",
      "source": "Drive Test / Walk Test",
      "method": "POST",
      "endpoint": "/api/import",
      "contentType": "multipart/form-data",
      "fileField": "file",
      "sampleFile": "exemple_drive_test_complet.csv",
      "expectedStatus": 200,
      "expectedResponse": {
        "success": true,
        "format": "csv",
        "total": 15,
        "imported": 15,
        "errors": 0
      },
      "curlCommand": "curl -X POST http://localhost:3000/api/import -H 'Cookie: <session>' -F 'file=@exemple_drive_test_complet.csv'"
    },
    {
      "id": 2,

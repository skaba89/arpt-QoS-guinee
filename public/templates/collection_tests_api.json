      "body": {
        "type": "DEGRADATION",
        "severity": "CRITIQUE",
        "message": "RSRP inférieur à -110 dBm sur 40% des mesures à Conakry",
        "details": "Seuil critique dépassé: RSRP moyen = -115 dBm. Zone: Kaloum, Dixinn."
      },
      "expectedStatus": 200,
      "curlCommand": "curl -X POST http://localhost:3000/api/alerts -H 'Cookie: <session>' -H 'Content-Type: application/json' -d '{\"type\":\"DEGRADATION\",\"severity\":\"CRITIQUE\",\"message\":\"RSRP inférieur à -110 dBm\"}'"
    },
